# ── AegisFlow configuration (example) ─────────────────────────────────────────
# Copy to .env. NEVER commit real secrets. In production these come from Vault
# via the External Secrets Operator, not from a file.

# Core
AEGIS_ENV=local
AEGIS_LOG_LEVEL=INFO
AEGIS_SECRET_KEY=change-me-32-bytes-min-rotate-via-vault
AEGIS_ALLOWED_ORIGINS=http://localhost:5173

# Connector mode: "mock" runs fully offline; "live" requires the keys below.
AEGIS_CONNECTOR_MODE=mock

# Persistence backend: "memory" (self-contained) or "postgres" (RLS-isolated).
AEGIS_PERSISTENCE=memory

# Postgres — in postgres mode connect as a NON-superuser role (superusers bypass
# Row-Level Security). The compose stack provisions 'aegis_app' for this.
AEGIS_DATABASE_URL=postgresql+psycopg://aegis_app:aegis_app@localhost:5432/aegis
# Neo4j
AEGIS_NEO4J_URI=bolt://localhost:7687
AEGIS_NEO4J_USER=neo4j
AEGIS_NEO4J_PASSWORD=aegis-neo4j
# Redis
AEGIS_REDIS_URL=redis://localhost:6379/0
# Kafka
AEGIS_KAFKA_BOOTSTRAP=localhost:9092
AEGIS_KAFKA_ALERTS_TOPIC=aegis.alerts
AEGIS_KAFKA_DLQ_TOPIC=aegis.alerts.dlq
AEGIS_KAFKA_GROUP_ID=aegisflow-ingest

# Investigation dispatch: inline (in-process) | temporal (durable workflows)
AEGIS_DISPATCH=inline
AEGIS_MAX_CONCURRENT_INVESTIGATIONS=100
# Temporal
AEGIS_TEMPORAL_HOST=localhost:7233

# OIDC / Keycloak (auth is delegated — we never roll our own)
AEGIS_OIDC_ISSUER=http://localhost:8080/realms/aegisflow
AEGIS_OIDC_AUDIENCE=aegisflow-api
AEGIS_OIDC_JWKS_URL=http://localhost:8080/realms/aegisflow/protocol/openid-connect/certs

# Threat Intel (only used when AEGIS_CONNECTOR_MODE=live)
AEGIS_VIRUSTOTAL_API_KEY=
AEGIS_ABUSEIPDB_API_KEY=
AEGIS_GREYNOISE_API_KEY=
AEGIS_OTX_API_KEY=
AEGIS_OPENCTI_URL=
AEGIS_OPENCTI_TOKEN=
AEGIS_MISP_URL=
AEGIS_MISP_KEY=

# Self-hosted sandbox (CAPEv2) — only used when AEGIS_CONNECTOR_MODE=live
AEGIS_CAPE_URL=
AEGIS_CAPE_TOKEN=
# Verify TLS to self-hosted TI/sandbox platforms (set False only for labs)
AEGIS_INTERNAL_TLS_VERIFY=true

# AI Copilot (Ollama, self-hosted)
# Model routing: preference-ordered provider chain; first configured wins.
# anthropic = cloud (needs AEGIS_ANTHROPIC_API_KEY); ollama = local/air-gapped.
AEGIS_LLM_PROVIDER_ORDER=anthropic,ollama
AEGIS_LLM_TIMEOUT_SECONDS=60
AEGIS_ANTHROPIC_API_KEY=
AEGIS_ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
AEGIS_ANTHROPIC_MODEL_DEEP=claude-sonnet-5
AEGIS_OLLAMA_BASE_URL=http://localhost:11434
AEGIS_OLLAMA_MODEL=llama3.1
AEGIS_OLLAMA_MODEL_FAST=

# Ticketing
AEGIS_SERVICENOW_INSTANCE=
AEGIS_SERVICENOW_USER=
AEGIS_SERVICENOW_PASSWORD=
AEGIS_JIRA_URL=
AEGIS_JIRA_USER=
AEGIS_JIRA_TOKEN=
