# AegisFlow frontend configuration (Vite). Copy to .env.local for local overrides.
# Only VITE_* vars are exposed to the browser bundle — never put secrets here.

# Backend API base. In dev, Vite proxies /api -> http://localhost:8000.
VITE_API_BASE_URL=/api/v1

# Keycloak (OIDC). The SPA uses the PUBLIC client 'aegisflow-spa' (PKCE, no secret).
VITE_OIDC_URL=http://localhost:8080
VITE_OIDC_REALM=aegisflow
VITE_OIDC_CLIENT_ID=aegisflow-spa

# Allow the header-based dev login button (local API with AEGIS_AUTH_DEV_BYPASS=true).
# Automatically disabled in production builds.
VITE_DEV_LOGIN=true
